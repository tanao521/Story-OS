# Story OS example environment file
# Copy this to .env and fill in your real values.

# Formal chapter generation
LLM_PROVIDER=api
WRITE_MODEL_BASE_URL=https://api.openai.com/v1
WRITE_MODEL_NAME=gpt-4o
WRITE_MODEL_API_KEY=
WRITE_MODEL_TIMEOUT_SECONDS=180
# Optional aliases also supported: MODEL_* / OPENAI_* / DEEPSEEK_*

# Legacy / optional local setup
# Local Ollama is kept only for legacy or experimental use.
# It is not the recommended path for formal chapter generation.
LOCAL_MODEL_API_KEY=ollama
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=qwen2.5:7b
USE_LOCAL_MODEL_FOR_DRAFT=false

# Other LLM services
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
USE_DEEPSEEK_FOR_EDITING=false
USE_DEEPSEEK_FOR_QUALITY_CHECK=false
USE_DEEPSEEK_FOR_QA=false

# Project settings
DATA_DIR=data
CONFIG_DIR=.story_os

# Obsidian sync
# OBSIDIAN_VAULT_DIR=D:/YourObsidianVault
# OBSIDIAN_PROJECT_DIR_NAME=StoryOS

# Logging and debug
LOG_LEVEL=INFO
LLM_DEBUG=false
